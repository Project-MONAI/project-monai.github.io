---
import BaseLayout from '../layouts/BaseLayout.astro';
const frontmatter = {
  title: 'MONAI - HAI Working Group: How We Work',
  description: 'Practical operations guide for the MONAI Human-AI Interaction Working Group - principles, processes, and collaboration guidelines.',
  canonical: 'https://project-monai.github.io/wg_hai_how_we_work.html',
};
---
<BaseLayout {...frontmatter}>
    <!-- Hero Section -->
    <section id="hero" class="relative overflow-hidden py-24 bg-gradient-to-br from-white via-brand-light/40 to-white">
      <div class="container">
        <div class="flex flex-wrap items-start gap-12">
          <div class="w-full max-w-3xl mx-auto">
            <p class="text-sm font-semibold mb-4 text-center">
              <a href="wg_human_ai_interaction.html" class="text-brand-teal hover:text-brand-dark transition-colors">&larr; Back to HAI Working Group</a>
            </p>
            <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-8 text-center">
              <span class="text-gray-900">How We Work</span>
            </h1>
            <p class="text-lg md:text-xl leading-relaxed text-gray-600 max-w-2xl mx-auto text-center mb-12">This document describes the practical operation of the MONAI Human-AI Interaction Working Group (WG).</p>
            <nav class="max-w-2xl mx-auto">
              <h2 class="text-sm font-semibold text-brand-teal uppercase tracking-widest mb-4 text-center">On this page</h2>
              <ul class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-2 text-sm">
                <li><a href="#guiding-principles" class="text-gray-600 hover:text-brand-teal transition-colors">&bull; Guiding Principles</a></li>
                <li><a href="#the-hai-way" class="text-gray-600 hover:text-brand-teal transition-colors">&bull; The HAI Way</a></li>
                <li><a href="#coordination-hub" class="text-gray-600 hover:text-brand-teal transition-colors">&bull; Our Coordination Hub</a></li>
                <li><a href="#what-belongs-in-an-issue" class="text-gray-600 hover:text-brand-teal transition-colors">&bull; What Belongs in an Issue?</a></li>
                <li><a href="#how-work-gets-done" class="text-gray-600 hover:text-brand-teal transition-colors">&bull; How Work Gets Done</a></li>
                <li><a href="#request-discussion" class="text-gray-600 hover:text-brand-teal transition-colors">&bull; When to Request WG Discussion</a></li>
                <li><a href="#meeting-structure" class="text-gray-600 hover:text-brand-teal transition-colors">&bull; WG Meeting Structure</a></li>
                <li><a href="#meeting-documentation" class="text-gray-600 hover:text-brand-teal transition-colors">&bull; Meeting Documentation</a></li>
                <li><a href="#issue-grooming" class="text-gray-600 hover:text-brand-teal transition-colors">&bull; Issue Grooming Process</a></li>
                <li><a href="#coordinators" class="text-gray-600 hover:text-brand-teal transition-colors">&bull; Who Coordinates the WG?</a></li>
                <li><a href="#communication-channels" class="text-gray-600 hover:text-brand-teal transition-colors">&bull; Communication Channels</a></li>
                <li><a href="#conflict-resolution" class="text-gray-600 hover:text-brand-teal transition-colors">&bull; Conflict Resolution</a></li>
                <li><a href="#why-this-approach" class="text-gray-600 hover:text-brand-teal transition-colors">&bull; Why This Approach?</a></li>
                <li><a href="#getting-started" class="text-gray-600 hover:text-brand-teal transition-colors">&bull; Getting Started</a></li>
              </ul>
            </nav>
          </div>
        </div>
      </div>
    </section>

    <!-- Guiding Principles Section -->
    <section id="guiding-principles" class="relative py-24 bg-gray-50">
      <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-brand-primary/30 to-transparent"></div>
      <div class="container">
        <p class="text-sm font-semibold text-brand-teal uppercase tracking-widest mb-4 text-center">Foundation</p>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 tracking-tight mb-6 text-center max-w-3xl mx-auto">Guiding Principles</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <div class="group p-8 rounded-xl border border-gray-100 hover:border-brand-primary/30 bg-white hover:shadow-lg hover:shadow-brand-primary/5 transition-all duration-300">
            <h3 class="text-lg font-bold text-gray-900 mb-2">Issue-driven</h3>
            <p class="text-gray-500 text-sm leading-relaxed">GitHub issues are our system of record</p>
          </div>
          <div class="group p-8 rounded-xl border border-gray-100 hover:border-brand-primary/30 bg-white hover:shadow-lg hover:shadow-brand-primary/5 transition-all duration-300">
            <h3 class="text-lg font-bold text-gray-900 mb-2">Async-first</h3>
            <p class="text-gray-500 text-sm leading-relaxed">Work happens primarily between meetings</p>
          </div>
          <div class="group p-8 rounded-xl border border-gray-100 hover:border-brand-primary/30 bg-white hover:shadow-lg hover:shadow-brand-primary/5 transition-all duration-300">
            <h3 class="text-lg font-bold text-gray-900 mb-2">Low barrier</h3>
            <p class="text-gray-500 text-sm leading-relaxed">Early and imperfect ideas are welcome</p>
          </div>
          <div class="group p-8 rounded-xl border border-gray-100 hover:border-brand-primary/30 bg-white hover:shadow-lg hover:shadow-brand-primary/5 transition-all duration-300">
            <h3 class="text-lg font-bold text-gray-900 mb-2">Transparent</h3>
            <p class="text-gray-500 text-sm leading-relaxed">Priorities, discussions, and agendas are public</p>
          </div>
          <div class="group p-8 rounded-xl border border-gray-100 hover:border-brand-primary/30 bg-white hover:shadow-lg hover:shadow-brand-primary/5 transition-all duration-300">
            <h3 class="text-lg font-bold text-gray-900 mb-2">Community-led</h3>
            <p class="text-gray-500 text-sm leading-relaxed">Anyone can contribute or claim work</p>
          </div>
        </div>
      </div>
    </section>

    <!-- The HAI Way Section -->
    <section id="the-hai-way" class="py-24 bg-white">
      <div class="container">
        <p class="text-sm font-semibold text-brand-teal uppercase tracking-widest mb-4 text-center">Culture</p>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 tracking-tight mb-4 text-center max-w-3xl mx-auto">The HAI Way</h2>
        <p class="text-lg text-gray-600 leading-relaxed mb-8 italic text-center max-w-3xl mx-auto">Principles for productive collaboration, inspired by those who came before us:</p>
        <div class="bg-white p-8 rounded-xl border border-gray-200 hover:border-brand-primary hover:shadow-lg transition-all duration-300">
          <ul class="space-y-4 text-gray-700">
            <li class="flex items-start">
              <span class="text-brand-teal mr-3 font-bold">&bull;</span>
              <span><strong>Joining a ticket is better than starting a new one.</strong></span>
            </li>
            <li class="flex items-start">
              <span class="text-brand-teal mr-3 font-bold">&bull;</span>
              <span><strong>Starting a new one is better than staying silent.</strong> <em>(When in doubt, create it.)</em></span>
            </li>
            <li class="flex items-start">
              <span class="text-brand-teal mr-3 font-bold">&bull;</span>
              <span><strong>Decisions live in issues, not in meetings.</strong></span>
            </li>
            <li class="flex items-start">
              <span class="text-brand-teal mr-3 font-bold">&bull;</span>
              <span><strong>Meeting notes capture "what happened," issues capture "what we decided."</strong></span>
            </li>
            <li class="flex items-start">
              <span class="text-brand-teal mr-3 font-bold">&bull;</span>
              <span><strong>Progress happens asynchronously; meetings exist to unblock.</strong></span>
            </li>
            <li class="flex items-start">
              <span class="text-brand-teal mr-3 font-bold">&bull;</span>
              <span><strong>Imperfect contributions beat perfect silence.</strong></span>
            </li>
            <li class="flex items-start">
              <span class="text-brand-teal mr-3 font-bold">&bull;</span>
              <span><strong>If it's important enough to discuss, it's important enough to document.</strong></span>
            </li>
            <li class="flex items-start">
              <span class="text-brand-teal mr-3 font-bold">&bull;</span>
              <span><strong>Transparent is better than efficient.</strong> <em>(When forced to choose.)</em></span>
            </li>
            <li class="flex items-start">
              <span class="text-brand-teal mr-3 font-bold">&bull;</span>
              <span><strong>Anyone can contribute. Everyone can claim work.</strong></span>
            </li>
            <li class="flex items-start">
              <span class="text-brand-teal mr-3 font-bold">&bull;</span>
              <span><strong>Subscribe before you criticize</strong> - context helps.</span>
            </li>
            <li class="flex items-start">
              <span class="text-brand-teal mr-3 font-bold">&bull;</span>
              <span><strong>If something blocks you, speak up.</strong> We're here to unblock each other.</span>
            </li>
            <li class="flex items-start">
              <span class="text-brand-teal mr-3 font-bold">&bull;</span>
              <span><strong>Before it's lost in Slack/Mailinglist, capture it in GitHub.</strong></span>
            </li>
          </ul>
          <p class="text-gray-500 italic mt-6 pt-4 border-t border-gray-200">These aren't rules - they're agreements on how we work best together.</p>
        </div>
      </div>
    </section>

    <!-- Coordination Hub Section -->
    <section id="coordination-hub" class="py-24 bg-gray-50">
      <div class="container">
        <p class="text-sm font-semibold text-brand-teal uppercase tracking-widest mb-4 text-center">Tools</p>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 tracking-tight mb-6 text-center max-w-3xl mx-auto">Our Coordination Hub</h2>
        <p class="text-lg text-gray-600 leading-relaxed mb-8 text-center max-w-3xl mx-auto">All technical discussions, proposals, and decisions are documented in <strong class="text-gray-700">GitHub issues</strong>.</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="bg-white p-8 rounded-xl border border-gray-200 hover:border-brand-primary hover:shadow-lg transition-all duration-300">
            <h3 class="text-xl font-semibold text-brand-teal mb-6 pb-2 border-b border-gray-200">WG Project Board</h3>
            <p class="text-gray-500 leading-relaxed mb-4">Central coordination space for all WG activities</p>
            <a href="https://github.com/orgs/Project-MONAI/projects/28" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm font-semibold text-brand-teal hover:text-brand-dark group/link transition-colors">
              View Project Board
              <svg class="w-4 h-4 transition-transform group-hover/link:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
              </svg>
            </a>
          </div>
          <div class="bg-white p-8 rounded-xl border border-gray-200 hover:border-brand-primary hover:shadow-lg transition-all duration-300">
            <h3 class="text-xl font-semibold text-brand-teal mb-6 pb-2 border-b border-gray-200">MONAI Label Milestones</h3>
            <p class="text-gray-500 leading-relaxed mb-4">Focus areas and medium-term direction (not strict deadlines)</p>
            <a href="https://github.com/Project-MONAI/MONAILabel/milestones" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm font-semibold text-brand-teal hover:text-brand-dark group/link transition-colors">
              View Milestones
              <svg class="w-4 h-4 transition-transform group-hover/link:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- What Belongs in an Issue Section -->
    <section id="what-belongs-in-an-issue" class="py-24 bg-white">
      <div class="container">
        <p class="text-sm font-semibold text-brand-teal uppercase tracking-widest mb-4 text-center">Issues</p>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 tracking-tight mb-6 text-center max-w-3xl mx-auto">What Belongs in an Issue?</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="bg-white p-8 rounded-xl border border-gray-200 hover:border-brand-primary hover:shadow-lg transition-all duration-300">
            <h3 class="text-xl font-semibold text-brand-teal mb-6 pb-2 border-b border-gray-200">Issues can represent:</h3>
            <ul class="space-y-4 text-gray-700">
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">&bull;</span>
                <span>Feature ideas or enhancement proposals</span>
              </li>
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">&bull;</span>
                <span>Bugs or technical problems</span>
              </li>
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">&bull;</span>
                <span>Discussion topics or open questions</span>
              </li>
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">&bull;</span>
                <span>Workflow improvements</span>
              </li>
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">&bull;</span>
                <span>Research or UX questions</span>
              </li>
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">&bull;</span>
                <span>Presentation proposals for WG meetings</span>
              </li>
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">&bull;</span>
                <span>Anything else relevant to human-AI interaction in medical imaging</span>
              </li>
            </ul>
          </div>
          <div class="bg-white p-8 rounded-xl border border-gray-200 hover:border-brand-primary hover:shadow-lg transition-all duration-300">
            <h3 class="text-xl font-semibold text-brand-teal mb-6 pb-2 border-b border-gray-200">Important Notes</h3>
            <div class="space-y-4 text-gray-700">
              <p><strong>Issues don't need to be perfect.</strong> A short description is enough to start the conversation.</p>
              <p><strong>Before creating a new issue:</strong> Check if a similar one already exists. If you're unsure, create it anyway - we'd rather have duplicates than miss your input.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- How Work Gets Done Section -->
    <section id="how-work-gets-done" class="py-24 bg-gray-50">
      <div class="container">
        <p class="text-sm font-semibold text-brand-teal uppercase tracking-widest mb-4 text-center">Process</p>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 tracking-tight mb-6 text-center max-w-3xl mx-auto">How Work Gets Done</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
          <div class="group p-8 rounded-xl border border-gray-100 hover:border-brand-primary/30 bg-white hover:shadow-lg hover:shadow-brand-primary/5 transition-all duration-300">
            <div class="text-3xl font-bold text-brand-accent mb-2">1</div>
            <h3 class="text-lg font-bold text-gray-900 mb-2">Claim an Issue</h3>
            <p class="text-gray-500 text-sm leading-relaxed">Assign yourself and indicate you'll work on it</p>
          </div>
          <div class="group p-8 rounded-xl border border-gray-100 hover:border-brand-primary/30 bg-white hover:shadow-lg hover:shadow-brand-primary/5 transition-all duration-300">
            <div class="text-3xl font-bold text-brand-accent mb-2">2</div>
            <h3 class="text-lg font-bold text-gray-900 mb-2">Work Async</h3>
            <p class="text-gray-500 text-sm leading-relaxed">Progress through comments, commits, and collaboration</p>
          </div>
          <div class="group p-8 rounded-xl border border-gray-100 hover:border-brand-primary/30 bg-white hover:shadow-lg hover:shadow-brand-primary/5 transition-all duration-300">
            <div class="text-3xl font-bold text-brand-accent mb-2">3</div>
            <h3 class="text-lg font-bold text-gray-900 mb-2">Others Join</h3>
            <p class="text-gray-500 text-sm leading-relaxed">By subscribing, commenting, or co-developing</p>
          </div>
          <div class="group p-8 rounded-xl border border-gray-100 hover:border-brand-primary/30 bg-white hover:shadow-lg hover:shadow-brand-primary/5 transition-all duration-300">
            <div class="text-3xl font-bold text-brand-accent mb-2">4</div>
            <h3 class="text-lg font-bold text-gray-900 mb-2">Share Updates</h3>
            <p class="text-gray-500 text-sm leading-relaxed">Directly in the issue thread</p>
          </div>
        </div>
        <div class="bg-white border border-gray-200 p-6 rounded-xl">
          <p class="text-gray-700"><strong>The WG meeting is not where implementation happens.</strong> It's where we unblock, align, and connect.</p>
        </div>
      </div>
    </section>

    <!-- When to Request WG Discussion Section -->
    <section id="request-discussion" class="py-24 bg-white">
      <div class="container">
        <p class="text-sm font-semibold text-brand-teal uppercase tracking-widest mb-4 text-center">Escalation</p>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 tracking-tight mb-6 text-center max-w-3xl mx-auto">When to Request WG Discussion</h2>
        <p class="text-lg text-gray-600 leading-relaxed mb-8 text-center max-w-3xl mx-auto">If you're working on an issue and need broader input:</p>
        <div class="bg-white p-8 rounded-xl border border-gray-200 hover:border-brand-primary hover:shadow-lg transition-all duration-300">
          <ol class="space-y-4 text-gray-700">
            <li class="flex items-start">
              <span class="bg-brand-primary text-gray-900 rounded-full w-6 h-6 flex items-center justify-center text-sm font-bold mr-3 flex-shrink-0">1</span>
              <span>Move it to or label it <strong>"Needs Discussion"</strong></span>
            </li>
            <li class="flex items-start">
              <span class="bg-brand-primary text-gray-900 rounded-full w-6 h-6 flex items-center justify-center text-sm font-bold mr-3 flex-shrink-0">2</span>
              <span>A coordinator will schedule it for the next WG meeting</span>
            </li>
            <li class="flex items-start">
              <span class="bg-brand-primary text-gray-900 rounded-full w-6 h-6 flex items-center justify-center text-sm font-bold mr-3 flex-shrink-0">3</span>
              <span>It appears in the <strong>"Next WG Meeting"</strong> column</span>
            </li>
          </ol>
        </div>
      </div>
    </section>

    <!-- WG Meeting Structure Section -->
    <section id="meeting-structure" class="py-24 bg-gray-50">
      <div class="container">
        <p class="text-sm font-semibold text-brand-teal uppercase tracking-widest mb-4 text-center">Meetings</p>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 tracking-tight mb-6 text-center max-w-3xl mx-auto">WG Meeting Structure</h2>
        <p class="text-lg text-gray-600 leading-relaxed mb-8 text-center max-w-3xl mx-auto">Meetings serve four purposes:</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
          <div class="group p-8 rounded-xl border border-gray-100 hover:border-brand-primary/30 bg-white hover:shadow-lg hover:shadow-brand-primary/5 transition-all duration-300">
            <h3 class="text-lg font-bold text-gray-900 mb-2">Community touchpoint</h3>
            <p class="text-gray-500 text-sm leading-relaxed">Staying connected as a group</p>
          </div>
          <div class="group p-8 rounded-xl border border-gray-100 hover:border-brand-primary/30 bg-white hover:shadow-lg hover:shadow-brand-primary/5 transition-all duration-300">
            <h3 class="text-lg font-bold text-gray-900 mb-2">Unblocking discussions</h3>
            <p class="text-gray-500 text-sm leading-relaxed">Addressing issues that need WG-level input</p>
          </div>
          <div class="group p-8 rounded-xl border border-gray-100 hover:border-brand-primary/30 bg-white hover:shadow-lg hover:shadow-brand-primary/5 transition-all duration-300">
            <h3 class="text-lg font-bold text-gray-900 mb-2">Issue grooming</h3>
            <p class="text-gray-500 text-sm leading-relaxed">Reviewing new issues, identifying duplicates, assigning milestones</p>
          </div>
          <div class="group p-8 rounded-xl border border-gray-100 hover:border-brand-primary/30 bg-white hover:shadow-lg hover:shadow-brand-primary/5 transition-all duration-300">
            <h3 class="text-lg font-bold text-gray-900 mb-2">Knowledge sharing</h3>
            <p class="text-gray-500 text-sm leading-relaxed">Short presentations on relevant topics (when proposed)</p>
          </div>
        </div>
        <div class="bg-white border border-gray-200 p-6 rounded-xl">
          <p class="text-gray-700"><strong>The "Next WG Meeting" column is the agenda.</strong> It's frozen ~1 week before each meeting so you can decide if attendance is valuable for you.</p>
        </div>
      </div>
    </section>

    <!-- Meeting Documentation Section -->
    <section id="meeting-documentation" class="py-24 bg-white">
      <div class="container">
        <p class="text-sm font-semibold text-brand-teal uppercase tracking-widest mb-4 text-center">Documentation</p>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 tracking-tight mb-6 text-center max-w-3xl mx-auto">Meeting Documentation</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="bg-white p-8 rounded-xl border border-gray-200 hover:border-brand-primary hover:shadow-lg transition-all duration-300">
            <h3 class="text-xl font-semibold text-brand-teal mb-6 pb-2 border-b border-gray-200">Meeting notes capture:</h3>
            <p class="text-gray-700 mb-4"><strong>Organizational information only</strong></p>
            <ul class="space-y-4 text-gray-700">
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">&bull;</span>
                <span>Scheduling updates</span>
              </li>
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">&bull;</span>
                <span>Process changes</span>
              </li>
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">&bull;</span>
                <span>Announcements</span>
              </li>
            </ul>
          </div>
          <div class="bg-white p-8 rounded-xl border border-gray-200 hover:border-brand-primary hover:shadow-lg transition-all duration-300">
            <h3 class="text-xl font-semibold text-brand-teal mb-6 pb-2 border-b border-gray-200">Why this approach?</h3>
            <p class="text-gray-700 mb-4"><strong>All technical discussions and decisions are documented in the issues themselves</strong>, not in meeting minutes. This ensures:</p>
            <ul class="space-y-4 text-gray-700">
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">&bull;</span>
                <span>Contributors who can't attend aren't disadvantaged</span>
              </li>
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">&bull;</span>
                <span>Discussions remain searchable and accessible</span>
              </li>
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">&bull;</span>
                <span>Participation works across time zones</span>
              </li>
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">&bull;</span>
                <span>Context is preserved where it belongs</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Issue Grooming Process Section -->
    <section id="issue-grooming" class="py-24 bg-gray-50">
      <div class="container">
        <p class="text-sm font-semibold text-brand-teal uppercase tracking-widest mb-4 text-center">Maintenance</p>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 tracking-tight mb-6 text-center max-w-3xl mx-auto">Issue Grooming Process</h2>
        <p class="text-lg text-gray-600 leading-relaxed mb-8 text-center max-w-3xl mx-auto">At each meeting, we review:</p>
