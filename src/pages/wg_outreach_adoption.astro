---
import BaseLayout from '../layouts/BaseLayout.astro';
const frontmatter = {
  title: 'MONAI - Outreach and Adoption Working Group',
  description: 'Establishing MONAI as a common software foundation for the Medical Imaging research and development community.',
  canonical: 'https://project-monai.github.io/wg_outreach_adoption.html',
};
---
<BaseLayout {...frontmatter}>
    <!-- Hero Section -->
    <section id="hero" class="relative overflow-hidden py-24 bg-gradient-to-br from-white via-brand-light/40 to-white">
      <div class="container">
        <div class="flex flex-wrap items-center">
          <div class="w-full max-w-3xl mx-auto text-center">
            <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-8">
              <span class="text-brand-accent">Outreach and Adoption</span><br>
              <span class="text-gray-900">Working Group</span>
            </h1>
            <p class="text-brand-teal uppercase tracking-widest text-sm font-semibold mb-4">Mission Statement</p>
            <p class="text-lg leading-relaxed text-gray-600">This working group aims to expand MONAI's reach and impact across the medical imaging community. The focus includes organizing technical training, fostering community engagement, and developing infrastructure with the end goal of establishing MONAI as the leading open-source platform for medical imaging AI. By building an inclusive and transparent community, the group ensures sustainable growth and adoption of MONAI.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Initiatives Section -->
    <section class="py-24 bg-gray-50">
      <div class="container">
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 mb-8 text-center max-w-3xl mx-auto">Initiatives</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-8">
          <div class="bg-white p-8 rounded-xl border border-gray-200 hover:border-brand-primary hover:shadow-lg transition-all duration-300">
            <h3 class="text-xl font-semibold text-brand-teal mb-6 pb-2 border-b border-gray-200">Community Building</h3>
            <ul class="space-y-4 text-gray-700">
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">•</span>
                <span>MONAI Newsletter publication</span>
              </li>
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">•</span>
                <span>Community events organization</span>
              </li>
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">•</span>
                <span>Social media engagement</span>
              </li>
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">•</span>
                <span>Success stories showcase</span>
              </li>
            </ul>
          </div>

          <div class="bg-white p-8 rounded-xl border border-gray-200 hover:border-brand-primary hover:shadow-lg transition-all duration-300">
            <h3 class="text-xl font-semibold text-brand-teal mb-6 pb-2 border-b border-gray-200">Education & Training</h3>
            <ul class="space-y-4 text-gray-700">
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">•</span>
                <span>Technical bootcamps and workshops</span>
              </li>
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">•</span>
                <span>Webinar series development</span>
              </li>
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">•</span>
                <span>Hackathon event coordination</span>
              </li>
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">•</span>
                <span>Training materials creation</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Group Leads Section -->
    <section class="py-24 bg-white">
      <div class="container">
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 mb-8 text-center max-w-3xl mx-auto">Group Leads</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
          <div class="bg-white p-8 rounded-xl border border-gray-200 hover:border-brand-primary hover:shadow-lg transition-all duration-300">
            <div class="flex flex-col items-center text-center">
              <img loading="lazy" src="/assets/img/people/michael-zephyr.jpg" alt="Michael Zephyr" class="w-32 h-32 rounded-full object-cover mb-6 border-4 border-brand-light">
              <div>
                <p class="text-xl font-semibold text-gray-800 mb-2">Michael Zephyr</p>
                <p class="text-base text-gray-600 mb-1">Technical Product Manager</p>
                <p class="text-sm text-gray-600 mb-1">NVIDIA</p>
                <p class="text-sm font-medium text-brand-teal">Outreach Working Group Chair</p>
                <a href="https://www.linkedin.com/in/michael-zephyr" target="_blank" rel="noopener noreferrer" class="inline-flex items-center text-sm text-brand-teal hover:text-brand-dark mt-2">
                  <span>View Profile</span>
                  <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                  </svg>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Meeting Notes and Recordings Section -->
