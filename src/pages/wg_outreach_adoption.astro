    <!-- Resources Section -->
    <section class="py-24 bg-gray-50">
      <div class="container">
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 mb-8 text-center max-w-3xl mx-auto">Resources</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-8">
          <div class="bg-white p-8 rounded-xl border border-gray-200 hover:border-brand-primary hover:shadow-lg transition-all duration-300">
            <h3 class="text-xl font-semibold text-brand-teal mb-6 pb-2 border-b border-gray-200">Community Resources</h3>
            <ul class="space-y-4 text-gray-700">
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">•</span>
                <span><a href="https://monai.medium.com/" class="link-hover">MONAI Blog</a></span>
              </li>
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">•</span>
                <span><a href="https://github.com/Project-MONAI/MONAI/discussions" class="link-hover">MONAI Discussions</a></span>
              </li>
            </ul>
          </div>

          <div class="bg-white p-8 rounded-xl border border-gray-200 hover:border-brand-primary hover:shadow-lg transition-all duration-300">
            <h3 class="text-xl font-semibold text-brand-teal mb-6 pb-2 border-b border-gray-200">Development Resources</h3>
            <ul class="space-y-4 text-gray-700">
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">•</span>
                <span><a href="https://github.com/Project-MONAI/MONAI/blob/dev/CONTRIBUTING.md" class="link-hover">Contribution Guidelines</a></span>
              </li>
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">•</span>
                <span><a href="https://github.com/Project-MONAI/MONAI/wiki" class="link-hover">Development Wiki</a></span>
              </li>
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">•</span>
                <span><a href="https://monai.readthedocs.io" class="link-hover">Documentation</a></span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Collaboration Opportunities Section -->
    <section class="py-24 bg-white">
      <div class="container">
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 mb-8 text-center max-w-3xl mx-auto">Collaboration Opportunities</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-8">
          <div class="bg-white p-8 rounded-xl border border-gray-200 hover:border-brand-primary hover:shadow-lg transition-all duration-300">
            <h3 class="text-xl font-semibold text-brand-teal mb-6 pb-2 border-b border-gray-200">Content Creation</h3>
            <ul class="space-y-4 text-gray-700">
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">•</span>
                <span>Write blog posts and tutorials</span>
              </li>
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">•</span>
                <span>Share success stories and case studies</span>
              </li>
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">•</span>
                <span>Develop training materials</span>
              </li>
            </ul>
          </div>

          <div class="bg-white p-8 rounded-xl border border-gray-200 hover:border-brand-primary hover:shadow-lg transition-all duration-300">
            <h3 class="text-xl font-semibold text-brand-teal mb-6 pb-2 border-b border-gray-200">Community Engagement</h3>
            <ul class="space-y-4 text-gray-700">
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">•</span>
                <span>Join our regular working group meetings</span>
              </li>
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">•</span>
                <span>Organize local events and meetups</span>
              </li>
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">•</span>
                <span>Mentor new community members</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

  </BaseLayout>
