        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-8">
          <div class="bg-white p-8 rounded-xl border border-gray-200 hover:border-brand-primary hover:shadow-lg transition-all duration-300">
            <h3 class="text-xl font-semibold text-brand-teal mb-6 pb-2 border-b border-gray-200">Google Drive</h3>
            <ul class="space-y-4 text-gray-700">
            </ul>
          </div>

          <div class="bg-white p-8 rounded-xl border border-gray-200 hover:border-brand-primary hover:shadow-lg transition-all duration-300">
            <h3 class="text-xl font-semibold text-brand-teal mb-6 pb-2 border-b border-gray-200">Direct Links</h3>
            <ul class="space-y-4 text-gray-700">
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">•</span>
                <span><a href="https://link-to-meeting-1" class="link-hover">Meeting 1 - Date</a></span>
              </li>
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">•</span>
                <span><a href="https://link-to-meeting-2" class="link-hover">Meeting 2 - Date</a></span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section> -->

    <!-- Resources Section -->
    <section class="py-24 bg-gray-50">
      <div class="container">
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 mb-8 text-center max-w-3xl mx-auto">Resources</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-8">
          <div class="bg-white p-8 rounded-xl border border-gray-200 hover:border-brand-primary hover:shadow-lg transition-all duration-300">
            <h3 class="text-xl font-semibold text-brand-teal mb-6 pb-2 border-b border-gray-200">Educational Resources</h3>
            <ul class="space-y-4 text-gray-700">
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">•</span>
                <span><a href="https://github.com/Project-MONAI/tutorials" class="link-hover">MONAI Tutorials Repository</a></span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Collaboration Opportunities Section -->
    <section class="py-24 bg-white">
      <div class="container">
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 mb-8 text-center max-w-3xl mx-auto">Collaboration Opportunities</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-8">
          <div class="bg-white p-8 rounded-xl border border-gray-200 hover:border-brand-primary hover:shadow-lg transition-all duration-300">
            <h3 class="text-xl font-semibold text-brand-teal mb-6 pb-2 border-b border-gray-200">Content Development</h3>
            <ul class="space-y-4 text-gray-700">
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">•</span>
                <span>Contribute to tutorial development through our <a href="https://github.com/Project-MONAI/tutorials" class="text-brand-teal hover:text-brand-dark transition-colors duration-300">GitHub repository</a></span>
              </li>
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">•</span>
                <span>Share your educational materials and case studies</span>
              </li>
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">•</span>
                <span>Help develop training workshops and courses</span>
              </li>
            </ul>
          </div>

          <div class="bg-white p-8 rounded-xl border border-gray-200 hover:border-brand-primary hover:shadow-lg transition-all duration-300">
            <h3 class="text-xl font-semibold text-brand-teal mb-6 pb-2 border-b border-gray-200">Community Engagement</h3>
            <ul class="space-y-4 text-gray-700">
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">•</span>
                <span>Join our regular working group meetings</span>
              </li>
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">•</span>
                <span>Participate in educational program development</span>
              </li>
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">•</span>
                <span>Help shape the future of medical AI education</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

  </BaseLayout>
