---
import BaseLayout from '../layouts/BaseLayout.astro';
const frontmatter = {
  title: 'MONAI - Education Working Group',
  description: 'Accelerating the adoption of AI in medical imaging through comprehensive educational resources and training materials.',
  canonical: 'https://project-monai.github.io/wg_education.html',
};
---
<BaseLayout {...frontmatter}>
    <!-- Hero Section -->
    <section id="hero" class="relative overflow-hidden py-24 bg-gradient-to-br from-white via-brand-light/40 to-white">
      <div class="container">
        <div class="flex flex-wrap items-center">
          <div class="w-full max-w-3xl mx-auto text-center">
            <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-8">
              <span class="text-brand-accent">Education</span><br>
              <span class="text-gray-900">Working Group</span>
            </h1>
            <p class="text-brand-teal uppercase tracking-widest text-sm font-semibold mb-4">Mission Statement</p>
            <p class="text-lg leading-relaxed text-gray-600">This working group aims to accelerate the adoption of AI in medical imaging through comprehensive educational resources and training materials. The focus includes developing structured learning paths, hands-on tutorials, and practical exercises with the end goal of enabling researchers and clinicians to effectively utilize MONAI in their work. By creating accessible content for various skill levels, the group helps bridge the knowledge gap in medical imaging AI.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Initiatives Section -->
    <section class="py-24 bg-gray-50">
      <div class="container">
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 mb-8 text-center max-w-3xl mx-auto">Initiatives</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-8">
          <div class="bg-white p-8 rounded-xl border border-gray-200 hover:border-brand-primary hover:shadow-lg transition-all duration-300">
            <h3 class="text-xl font-semibold text-brand-teal mb-6 pb-2 border-b border-gray-200">Educational Content Development</h3>
            <ul class="space-y-4 text-gray-700">
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">•</span>
                <span>Creation of comprehensive tutorials and documentation</span>
              </li>
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">•</span>
                <span>Development of hands-on training materials</span>
              </li>
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">•</span>
                <span>Design of structured learning paths for different skill levels</span>
              </li>
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">•</span>
                <span>Integration of real-world medical imaging examples</span>
              </li>
            </ul>
          </div>

          <div class="bg-white p-8 rounded-xl border border-gray-200 hover:border-brand-primary hover:shadow-lg transition-all duration-300">
            <h3 class="text-xl font-semibold text-brand-teal mb-6 pb-2 border-b border-gray-200">Community Engagement</h3>
            <ul class="space-y-4 text-gray-700">
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">•</span>
                <span>Organization of workshops and training sessions</span>
              </li>
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">•</span>
                <span>Collaboration with academic institutions</span>
              </li>
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">•</span>
                <span>Development of certification programs</span>
              </li>
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">•</span>
                <span>Support for educational research projects</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Group Leads Section -->
    <section class="py-24 bg-white">
      <div class="container">
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 mb-8 text-center max-w-3xl mx-auto">Group Leads</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
          <div class="bg-white p-8 rounded-xl border border-gray-200 hover:border-brand-primary hover:shadow-lg transition-all duration-300">
            <div class="flex flex-col items-center text-center">
              <img loading="lazy" src="assets/img/people/eric-kerfoot.png" alt="Eric Kerfoot" class="w-32 h-32 rounded-full object-cover mb-6 border-4 border-brand-light">
              <div>
                <p class="text-xl font-semibold text-gray-800 mb-2">Eric Kerfoot</p>
                <p class="text-base text-gray-600 mb-1">Software Architect in Medical Engineering</p>
                <p class="text-sm text-gray-600 mb-1">King's College London</p>
                <p class="text-sm font-medium text-brand-teal">Education Working Group Chair</p>
                <div class="flex justify-center text-sm text-brand-teal hover:text-brand-dark mt-2">
                  <span>View Profile</span>
                  <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                  </svg>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-white p-8 rounded-xl border border-gray-200 hover:border-brand-primary hover:shadow-lg transition-all duration-300">
            <div class="flex flex-col items-center text-center">
              <img loading="lazy" src="assets/img/people/marc-modat.jpg" alt="Marc Modat" class="w-32 h-32 rounded-full object-cover mb-6 border-4 border-brand-light">
              <div>
                <p class="text-xl font-semibold text-gray-800 mb-2">Marc Modat</p>
                <p class="text-base text-gray-600 mb-1">Reader in Computational Imaging</p>
                <p class="text-sm text-gray-600 mb-1">King's College London</p>
                <p class="text-sm font-medium text-brand-teal">Education Working Group Chair</p>
                <div class="flex justify-center text-sm text-brand-teal hover:text-brand-dark mt-2">
                  <span>View Profile</span>
                  <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                  </svg>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Meeting Notes and Recordings Section -->
