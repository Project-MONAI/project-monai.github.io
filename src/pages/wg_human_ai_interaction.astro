    </section> -->

    <!-- Resources Section -->
    <section class="py-24 bg-white">
      <div class="container">
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 mb-8 text-center max-w-3xl mx-auto">Resources</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-8">
          <div class="bg-white p-8 rounded-xl border border-gray-200 hover:border-brand-primary hover:shadow-lg transition-all duration-300">
            <h3 class="text-xl font-semibold text-brand-teal mb-6 pb-2 border-b border-gray-200">Development Resources</h3>
            <ul class="space-y-4 text-gray-700">
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">•</span>
                <span><a href="wg_hai_how_we_work.html" class="link-hover">How We Work</a> - Our organizational process and principles</span>
              </li>
              <li class="flex items-start">
                <span class="text-brand-teal mr-3">•</span>
                <span><a href="https://github.com/orgs/Project-MONAI/projects/28" class="link-hover" target="_blank" rel="noopener noreferrer">WG Project Board</a> - Central coordination space</span>
              </li>
              <li class="flex items-start">
